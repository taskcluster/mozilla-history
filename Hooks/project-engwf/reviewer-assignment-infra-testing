{
  "bindings": [
    {
      "exchange": "exchange/taskcluster-github/v1/pull-request",
      "routingKeyPattern": "#.infra-testing.#"
    }
  ],
  "hookGroupId": "project-engwf",
  "hookId": "reviewer-assignment-infra-testing",
  "metadata": {
    "description": "*DO NOT EDIT* - This resource is configured automatically by [ci-admin](https://github.com/mozilla-releng/fxci-config).\n\nAutomatically assign reviewers to PRs",
    "emailOnError": true,
    "name": "Reviewer assignment hook (testing)",
    "owner": "omehani@mozilla.com"
  },
  "schedule": [],
  "task": {
    "tags": {},
    "extra": {},
    "routes": [
      "index.project.engwf.production.reviewer-assignment.latest"
    ],
    "scopes": [
      "notify:email:*",
      "secrets:get:project/engwf/reviewer-assignment/runtime-infra-testing",
      "index:insert-task:project.engwf.production.reviewer-assignment.*"
    ],
    "created": {
      "$fromNow": "0 seconds"
    },
    "expires": {
      "$fromNow": "1 month"
    },
    "payload": {
      "env": {
        "PR_URL": {
          "$eval": "payload.body.pull_request.html_url"
        },
        "DIFF_URL": {
          "$eval": "payload.body.pull_request.diff_url"
        },
        "ORG_NAME": {
          "$eval": "payload.organization"
        },
        "REPO_URL": {
          "$eval": "payload.body.repository.html_url"
        },
        "REPO_NAME": {
          "$eval": "payload.repository"
        },
        "TC_SECRET_ID": "project/engwf/reviewer-assignment/runtime-infra-testing",
        "TARGET_BRANCH_NAME": {
          "$eval": "payload.body.pull_request.base.ref"
        }
      },
      "image": "docker.io/omehani/moz-reviewer-selector",
      "features": {
        "taskclusterProxy": true
      },
      "maxRunTime": 7200,
      "capabilities": {}
    },
    "retries": 3,
    "deadline": {
      "$fromNow": "2 hours"
    },
    "metadata": {
      "name": "Reviewer assignment",
      "owner": "omehani@mozilla.com",
      "source": "https://github.com/mozilla-conduit/reviewer-selector",
      "description": "Assign reviewers for PRs in the mozilla-firefox/infra-testing repo"
    },
    "priority": "lowest",
    "workerType": "bot",
    "schedulerId": "engwf",
    "provisionerId": "code-review"
  },
  "triggerSchema": {
    "type": "object",
    "required": [
      "body",
      "organization",
      "repository"
    ],
    "properties": {
      "body": {
        "type": "object",
        "required": [
          "action",
          "pull_request",
          "repository"
        ],
        "properties": {
          "action": {
            "type": "string",
            "pattern": "^(opened|reopened|synchronize)$",
            "description": "Action on the PR"
          },
          "repository": {
            "type": "object",
            "required": [
              "html_url"
            ],
            "properties": {
              "html_url": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "pull_request": {
            "type": "object",
            "required": [
              "base",
              "diff_url",
              "html_url"
            ],
            "properties": {
              "base": {
                "type": "object",
                "required": [
                  "ref"
                ],
                "properties": {
                  "ref": {
                    "type": "string",
                    "description": "Target branch to merge this PR in"
                  }
                },
                "description": "Pull request metadata",
                "additionalProperties": true
              },
              "diff_url": {
                "type": "string"
              },
              "html_url": {
                "type": "string"
              }
            },
            "description": "Pull request metadata",
            "additionalProperties": true
          }
        },
        "description": "The raw body of github event (for version 1)\n",
        "additionalProperties": true
      },
      "repository": {
        "type": "string",
        "pattern": "^infra-testing$"
      },
      "organization": {
        "type": "string",
        "pattern": "^mozilla-firefox$"
      }
    },
    "additionalProperties": true
  }
}
